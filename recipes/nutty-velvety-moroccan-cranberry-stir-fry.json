{
  "title": "Nutty Velvety Moroccan Cranberry Stir-fry",
  "description": "A quick and easy weeknight dish featuring a nutty velvety texture with cranberries and a hint of sweetness.",
  "cuisine": "Moroccan",
  "diet": null,
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Canned crushed tomatoes",
      "amount": "1 can (400ml)"
    },
    {
      "name": "Olive oil",
      "amount": "2 tbsp"
    },
    {
      "name": "Minced garlic",
      "amount": "3 cloves"
    },
    {
      "name": "Fresh ginger",
      "amount": "1 tsp, minced"
    },
    {
      "name": "Cranberries",
      "amount": "1 cup (fresh or frozen)"
    },
    {
      "name": "Almonds",
      "amount": "2 tbsp, finely chopped"
    },
    {
      "name": "Walnuts",
      "amount": "2 tbsp, finely chopped"
    },
    {
      "name": "Dried apricots",
      "amount": "1/4 cup, chopped"
    },
    {
      "name": "Pomegranate molasses",
      "amount": "1 tbsp"
    },
    {
      "name": "Red pepper flakes",
      "amount": "1/4 tsp"
    },
    {
      "name": "Salt and pepper to taste",
      "notes": "to taste"
    }
  ],
  "instructions": [
    "Heat olive oil in a pan over medium heat.",
    "Add minced garlic and ginger, sauté for about 2 minutes until fragrant.",
    "Pour in crushed tomatoes, stir well, reduce heat to low, cover, and let simmer for about 10-15 minutes.",
    "Stir in cranberries, almonds, walnuts, dried apricots, pomegranate molasses, red pepper flakes, salt, and pepper. Cook for another 5-7 minutes until the mixture thickens slightly.",
    "Serve hot as a side dish or over rice."
  ],
