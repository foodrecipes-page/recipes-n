    },
    {
      "name": "ginger",
      "amount": "1 teaspoon ground"
    },
    {
      "name": "scallions",
      "amount": "2 scallions, sliced thinly"
    },
    {
      "name": "toasted sesame oil",
      "amount": "1 teaspoon"
    },
    {
      "name": "shredded carrots",
      "amount": "1 cup, julienned"
    }
  ],
  "instructions": [
    "Heat vegetable oil in a wok or large skillet over medium-high heat.",
    "Add tofu cubes and cook until golden brown on all sides. Remove from pan and set aside.",
    "In the same pan, add corn, broccoli, ginger, scallions, soy sauce, and sesame oil. Stir-fry for about 2 minutes.",
    "Return tofu to the pan with vegetables and mix well. Add peanut butter and continue to stir-fry until mixture is heated through and creamy.",
    "Garnish with toasted sesame seeds and sliced scallions before serving."
