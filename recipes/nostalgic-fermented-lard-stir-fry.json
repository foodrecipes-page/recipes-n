{
  "title": "Nostalgic Fermented Lard Stir-fry",
  "description": "A light and nostalgic Jamaican dish featuring fermented lard in a stir-fry that is egg-free-friendly.",
  "cuisine": "Jamaican",
  "diet": [
    "egg-free"
  ],
  "meal": "snack",
  "ingredients": [
    {
      "name": "fermented lard",
      "amount": "1/2 cup"
    },
    {
      "name": "green onions",
      "amount": "2 tbsp, chopped"
    },
    {
      "name": "fresh ginger",
      "amount": "1 tsp, minced"
    },
    {
      "name": "red bell pepper",
      "amount": "1 medium, thinly sliced"
    },
    {
      "name": "zucchini",
      "amount": "1 small, diced"
    },
    {
      "name": "lime juice",
      "amount": "2 tbsp"
    },
    {
      "name": "salt",
      "amount": "to taste"
    }
  ],
  "instructions": [
    "Heat a non-stick skillet over medium heat.",
    "Add fermented lard to the skillet and cook until it turns golden brown, about 5 minutes.",
    "Stir in green onions, ginger, red bell pepper, and zucchini. Cook for an additional 3-4 minutes or until vegetables are slightly softened.",
    "Drizzle with lime juice and add salt to taste. Stir gently to combine all ingredients.",
    "Serve immediately."
  ],
