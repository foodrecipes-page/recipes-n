      "name": "peanut butter",
      "amount": "1/2 cup"
    },
    {
      "name": "coconut oil",
      "amount": "1/4 cup"
    },
    {
      "name": "unsweetened cocoa powder",
      "amount": "3 tablespoons"
    },
    {
      "name": "honey or maple syrup",
      "amount": "2 tablespoons"
    },
    {
      "name": "pumpkin seeds",
      "amount": "1/4 cup"
    },
    {
      "name": "almond meal",
      "amount": "1/2 cup"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a mixing bowl, combine peanut butter and coconut oil until smooth.",
    "Add cocoa powder and mix well. Gradually add honey or maple syrup, stirring continuously to avoid clumping.",
    "Fold in pumpkin seeds and almond meal gently with a spatula until evenly distributed.",
    "Transfer mixture into an ungreased 8x8 inch baking dish and press down firmly to create one layer.",
    "Bake for about 15 minutes or until golden brown on top. Let cool completely before slicing."
  ],
