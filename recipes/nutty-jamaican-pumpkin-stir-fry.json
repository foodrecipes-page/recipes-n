{
  "title": "Nutty Jamaican Pumpkin Stir-fry",
  "description": "A lazy Sunday dish featuring mixed peel and fermented elements for a unique flavor twist, suitable for keto diets.",
  "cuisine": "Jamaican",
  "diet": [
    "keto"
  ],
  "meal": "dinner",
  "ingredients": [
    {
      "name": "Pumpkin",
      "amount": "1 medium pumpkin"
    },
    {
      "name": "Mixed Peel",
      "amount": "2 tbsp, finely chopped"
    },
    {
      "name": "Fermented Ginger Ale (optional)",
      "amount": "1/4 cup"
    },
    {
      "name": "Nutritional Yeast (for a cheesy flavor)",
      "amount": "1 tbsp"
    },
    {
      "name": "Garlic",
      "amount": "3 cloves"
    },
    {
      "name": "Cumin",
      "amount": "1 tsp"
    },
    {
      "name": "Oregano",
      "amount": "1/2 tsp"
    }
  ],
  "instructions": [
    "Preheat oven to 400°F (200°C).",
    "Cut the pumpkin into bite-sized pieces and place them on a baking sheet.",
    "Mix chopped mixed peel, fermented ginger ale (if using), nutritional yeast, garlic, cumin, and oregano together in a bowl. Drizzle with olive oil and sprinkle over the pumpkin slices.",
    "Bake for about 25 minutes or until golden brown.",
    "Serve hot as a side dish or a main course."
  ],
