    {
      "name": "bay leaves",
      "amount": "1-2 pieces"
    },
    {
      "name": "garlic cloves",
      "amount": "3-4, minced"
    },
    {
      "name": "onion",
      "amount": "1/2 medium, diced"
    },
    {
      "name": "celery stalks",
      "amount": "1 piece, finely chopped"
    },
    {
      "name": "carrots",
      "amount": "2-3 pieces, julienned"
    },
    {
      "name": "zucchini",
      "amount": "1 cup, julienne and lightly steamed"
    },
    {
      "name": "pistachios or almonds",
      "amount": "1/4 cup, crushed"
    },
    {
      "name": "sloppy joe sauce (gluten-free)",
      "amount": "2 tablespoons"
    },
    {
      "name": "vegetable broth",
      "amount": "6-8 ounces"
    },
    {
      "name": "heavy cream",
      "amount": "3/4 cup"
    },
    {
      "name": "salt and pepper to taste"
    }
  ],
  "instructions": [
    "Heat a large skillet over medium-high heat. Add bay leaves, garlic, onion, celery, and zest of one lemon.",
    "Sauté until the vegetables are slightly softened, about 5 minutes. Stir in steamed zucchini, carrots, and pistachios/almonds.",
    "Add sloppy joe sauce, vegetable broth, and heavy cream to the skillet, stirring well to combine. Bring to a simmer.",
    "Reduce heat to low and let cook for another 10-12 minutes until the sauce thickens slightly. Season with salt and pepper as needed."
  ],
