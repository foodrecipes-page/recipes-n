{
  "title": "Nutty Creamy Show-off Slovakian Stir-fry",
  "description": "A show-stopping dish featuring a nutty and creamy sauce infused with bay leaves that complements gluten-free-friendly vegetables and grains.",
  "cuisine": "Slovakian",
  "diet": [
    "gluten-free"
