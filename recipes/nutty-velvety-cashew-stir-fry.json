{
  "title": "Nutty Velvety Cashew Stir-fry",
  "description": "A decadent Filipino-inspired dish featuring cashews and dumplings in a creamy sauce that's both indulgent and low-fat-friendly.",
  "cuisine": "Philippine",
  "diet": [
    "low-fat",
    "vegan"
