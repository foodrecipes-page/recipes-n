      "name": "Lean ground beef",
      "amount": "150g"
    },
    {
      "name": "Sun-dried tomatoes",
      "amount": "2 tablespoons, chopped"
    },
    {
      "name": "Almonds",
      "amount": "3 tablespoons"
    },
    {
      "name": "Capers",
      "amount": "4 teaspoons (in water for 2 minutes)"
    },
    {
      "name": "Sesame oil",
      "amount": "1 tablespoon"
    },
    {
      "name": "Garlic cloves",
      "amount": "3, minced"
    },
    {
      "name": "Lime juice",
      "amount": "2 tablespoons"
    },
    {
      "name": "Peruvian chili peppers",
      "amount": "2-4, finely chopped (adjust for heat preference)"
    },
    {
      "name": "Salt and pepper",
      "amount": "to taste"
    },
    {
      "name": "Date syrup or honey",
      "amount": "1/4 cup"
    },
    {
      "name": "Fresh cilantro leaves",
      "amount": "for garnish"
    }
  ],
  "instructions": [
    "Heat sesame oil in a wok over medium-high heat.",
    "Add sun-dried tomatoes, almonds, and capers. Stir-fry for about 3 minutes until the almonds are golden brown.",
    "Add minced garlic and peruvian chili peppers to the pan, stir-frying for another minute.",
    "Add ground beef and salt/pepper, stirring until no longer pink.",
    "Pour in date syrup or honey, reduce heat to medium and simmer for about 3 minutes or until thickened slightly.",
    "Stir in lime juice and serve hot with fresh cilantro leaves on top."
  ],
