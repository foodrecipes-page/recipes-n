      "notes": "sliced thinly"
    },
    {
      "name": "olive oil",
      "amount": "3 tablespoons"
    },
    {
      "name": "red pepper flakes",
      "amount": "a pinch",
      "notes": "for heat, optional"
    },
    {
      "name": "salt",
      "amount": "to taste"
    },
    {
      "name": "black olives",
      "amount": "10-15",
      "notes": "halved"
    }
  ],
  "instructions": [
    "Heat olive oil in a large skillet over medium-high heat.",
    "Add chopped pine nuts and minced garlic to the pan, stir-fry for about 2 minutes until fragrant.",
    "Add diced onions and bell peppers to the pan; stir-fry for another 5-7 minutes until vegetables start to soften.",
    "Add zucchini slices and continue cooking for an additional 3-4 minutes.",
    "Toss in halved black olives, sprinkle with red pepper flakes if using, then season with salt to taste.",
    "Remove from heat once all the vegetables are tender and evenly coated with pine nuts.",
    "Serve hot as a light dinner or side dish."
  ],
