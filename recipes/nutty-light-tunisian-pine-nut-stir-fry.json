{
  "title": "Nutty Light Tunisian Pine Nut Stir-fry",
  "description": "A light and nutty solo-dinner dish featuring tender vegetables cooked with a blend of olive oil and pine nuts to create a vibrant and flavorful dish.",
  "cuisine": "Tunisian",
  "diet": null,
