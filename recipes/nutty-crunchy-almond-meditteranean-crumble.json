{
  "title": "Nutty Crunchy Almond Meditteranean Crumble",
  "description": "A sick-day dish featuring a gluten-free almond mediterranean crumble with caramelized palm sugar for added sweetness and crunch.",
  "cuisine": "Mediterranean",
  "diet": [
    "gluten-free"
  ],
  "meal": "dessert",
  "ingredients": [
    {
      "name": "Almond meal",
      "amount": "1/2 cup"
    },
    {
      "name": "Palm sugar (or coconut palm sugar)",
      "amount": "3 tbsp"
    },
    {
      "name": "Water",
      "amount": "2 tbsp"
    },
    {
      "name": "Coconut flakes",
      "amount": "1/4 cup"
    },
    {
      "name": "Almonds, chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Walnuts, chopped",
      "amount": "1/4 cup"
    },
    {
      "name": "Hazelnuts, chopped",
      "amount": "1/4 cup"
    }
  ],
  "instructions": [
    "Preheat oven to 350°F (175°C).",
    "In a small bowl, mix together almond meal and water until no lumps remain.",
    "Add palm sugar and stir until dissolved. Transfer mixture to a baking dish lined with parchment paper.",
    "Sprinkle coconut flakes evenly over the top of the crumble mixture.",
    "Top the creme brûlée layer with chopped almonds, walnuts, and hazelnuts.",
    "Bake in preheated oven for 20 minutes or until golden brown on top.",
    "Remove from oven and let cool slightly before serving."
  ],
